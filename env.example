APP_NAME="sixth-degree-py"
ENVIRONMENT="local"
LOG_LEVEL="INFO"

HOST="0.0.0.0"
PORT="8080"
CORS_ALLOW_ORIGINS="*"

# SQLAlchemy URL (psycopg v3)
DATABASE_URL="postgresql+psycopg://postgres:postgres@db:5432/sixth_degree"

REDIS_URL="redis://redis:6379/0"
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/1"

# Daily schedule (Celery Beat crontab)
# Default: 03:00 every day
WIKI_SYNC_CRON_MINUTE="0"
WIKI_SYNC_CRON_HOUR="3"

WIKI_USER_AGENT="SixthDegreePyBot/1.0 (Educational Project; contact: you@example.com)"

# Concurrency & limits
WIKI_MAX_WORKERS="10"
WIKI_MAX_RETRIES="3"


